                          <td style='padding:10px 14px; font:700 14px Arial,Helvetica,sans-serif; color:#EA580C; text-align:center; border-bottom:1px solid #f3f4f6; background:#fffaf5;'>Unlimited</td>
                        </tr>
                        <tr>
                          <td style='padding:10px 14px; font:14px Arial,Helvetica,sans-serif; color:#374151; border-bottom:1px solid #f3f4f6;'>API rate limit</td>
